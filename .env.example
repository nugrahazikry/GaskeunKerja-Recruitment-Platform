# ============================================================
# GaskeunKerja for Business — MVP (local) environment example
# Copy to `.env` and fill real values. NEVER commit the real .env.
# ============================================================

# ---- App ----
APP_ENV=dev
BACKEND_PORT=8000
FRONTEND_PORT=5173

# ---- LLM via SumoPod (OpenAI-compatible) ----
# All reasoning/extraction/scoring goes through SumoPod. No local LLM.
LLM_BASE_URL=https://ai.sumopod.com/v1
LLM_API_KEY=your_sumopod_api_key_here
LLM_MODEL_FLASH=deepseek-v4-flash          # extraction, CV parse, question gen
LLM_MODEL_PRO=deepseek-v4-pro              # skill-gap, rubric scoring
LLM_TEMPERATURE_SCORING=0                  # determinism for rubric scoring (Q17)

# ---- Speech-to-Text (STT) ----
# SumoPod has no STT, so STT uses a separate provider.
# Choose ONE: groq | openai | local
STT_PROVIDER=groq
STT_LANGUAGE=id                            # Bahasa Indonesia

# Option A (default): Groq whisper-large-v3 (OpenAI-compatible, free tier, fast)
STT_BASE_URL=https://api.groq.com/openai/v1
STT_API_KEY=your_groq_api_key_here
STT_MODEL=whisper-large-v3

# Option B: OpenAI whisper-1 (paid)
#   STT_PROVIDER=openai
#   STT_BASE_URL=https://api.openai.com/v1
#   STT_API_KEY=your_openai_api_key_here
#   STT_MODEL=whisper-1

# Option C: Local faster-whisper (free, uses your RTX 3050, audio stays on-device)
#   STT_PROVIDER=local
#   STT_LOCAL_MODEL=small                  # tiny|base|small|medium; small is a good id/GPU balance
#   STT_LOCAL_DEVICE=cuda                  # cuda (GPU) or cpu
#   STT_LOCAL_COMPUTE_TYPE=float16

# ---- Vision LLM (scanned-PDF image captioning — replaces OCR, see NalarX-pattern note) ----
# Choose ONE: groq | sumopod
# ⚠️ Day-1 verified 2026-07-13: SumoPod's deepseek-v4-pro does NOT support vision — it silently
# ignores the image_url content block (model's own reasoning_content confirms "no image provided"),
# burns tokens reasoning about the missing image, and returns empty. Groq is now PRIMARY, not fallback.
VISION_PROVIDER=groq

# Option A (default, verified working): Groq meta-llama/llama-4-scout-17b-16e-instruct.
# Reuses STT_BASE_URL / STT_API_KEY above (same Groq account/key).
VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Option B (do not use — confirmed non-functional 2026-07-13, kept only for reference):
#   VISION_PROVIDER=sumopod
#   VISION_MODEL=deepseek-v4-pro

# ---- Interview audio format (fixed, no config needed) ----
# WebM (Opus codec) universally — browser MediaRecorder's native output, accepted by
# Groq Whisper directly (no transcoding). Used for both live and seed/synthetic clips.

# ---- Embeddings ----
# Chosen: gemini-embedding-001 via SumoPod — top MTEB Multilingual score, best fit
# for Bahasa Indonesia CV/job-description semantic matching. Reuses LLM_BASE_URL /
# LLM_API_KEY above (SumoPod catalog includes it), no separate key needed.
# Choose ONE: sumopod | local
# ⚠️ Day-1 verified 2026-07-13: model id on SumoPod requires the "gemini/" prefix
# (bare "gemini-embedding-001" returns 400 Invalid model name). Dimension truncation to
# 1536 via the `dimensions` param confirmed working (returned vector is exactly 1536-dim).
EMBEDDING_PROVIDER=sumopod
EMBEDDING_MODEL=gemini/gemini-embedding-001
EMBEDDING_DIMENSIONS=1536                  # Matryoshka-truncated from native 3072 (Qdrant storage/speed)

# Fallback (free, fully offline, no vision/LLM verification needed): local sentence-transformers.
#   EMBEDDING_PROVIDER=local
#   EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# ---- Structured DB: PostgreSQL (Docker) ----
POSTGRES_USER=gaskeun
POSTGRES_PASSWORD=gaskeun_dev
POSTGRES_DB=gaskeun
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://gaskeun:gaskeun_dev@localhost:5432/gaskeun

# ---- Vector DB: Qdrant (Docker) ----
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_URL=http://localhost:6333

# ---- Auth (HR/recruiter login only — candidates use a token link, no account) ----
JWT_SECRET=change_me_to_a_random_string
JWT_EXPIRE_MINUTES=120
CANDIDATE_TOKEN_TTL_HOURS=72

# ---- Local file storage (CV + interview audio) ----
STORAGE_DIR=./storage

# ---- Telegram report delivery (automated, free — the ONLY delivery channel for MVP) ----
# Create a bot via @BotFather in Telegram -> get the token below.
# Candidate links their chat once via t.me/<bot_username>?start=<candidate_token>,
# which lets the backend push the report file + summary automatically.
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_BOT_USERNAME=your_bot_username_here
